async function enterWorld(name) {
  // 1. Fetch or create world seed
  const seedRef = ref(db, 'world/seed');
  const seedSnap = await get(seedRef);
  if (seedSnap.exists()) {
    worldSeed = seedSnap.val();
  } else {
    worldSeed = Math.floor(Math.random() * 2_000_000_000);
    await set(seedRef, worldSeed);
  }
  world = generateWorld(worldSeed);
  document.getElementById('s-seed').textContent = worldSeed;

  // 2. Check concurrent players
  const onlineSnap = await get(ref(db, 'online'));
  const onlineCount = onlineSnap.exists() ? Object.keys(onlineSnap.val()).length : 0;
  const exists = onlineSnap.exists() ? onlineSnap.val()[name] : null;
  if (!exists && onlineCount >= MAX_PLAYERS) {
    throw new Error(`server full (${MAX_PLAYERS} max)`);
  }

  // 3. Load or create player
  const playerRef = ref(db, `players/${name}`);
  const pSnap = await get(playerRef);
  if (pSnap.exists()) {
    me = pSnap.val();
    me.name = name;
  } else {
    // Find a walkable spawn near center
    let sx = 25, sy = 25, tries = 0;
    while (tries < 100 && !BIOMES[world[sy][sx].biome].walkable) {
      sx = 20 + Math.floor(Math.random() * 10);
      sy = 20 + Math.floor(Math.random() * 10);
      tries++;
    }
    me = {
      name, x: sx, y: sy,
      hp: 100, maxHp: 100,
      gold: 0, lvl: 1, xp: 0,
      inv: {}, tools: {},
      creatures: []
    };
    await set(playerRef, { ...me });
  }

  // 4. Mark online + set disconnect cleanup
  const onRef = ref(db, `online/${name}`);
  await set(onRef, { at: serverTimestamp() });
  onDisconnect(onRef).remove();

  // 5. Subscribe to world state
  setupListeners();

  // 6. Show game
  loginEl.style.display = 'none';
  gameEl.classList.add('active');
  document.getElementById('brand-name').textContent = name;
  fitCanvas();
  log(`welcome, ${name} — ${onlineCount + (exists ? 0 : 1)}/5 online`, 'system');
  startGameLoop();
}

