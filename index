// FIREBASE LISTENERS
// ============================================================
function setupListeners() {
  // online count + other players' lightweight state
  onValue(ref(db, 'online'), snap => {
    const val = snap.val() || {};
    document.getElementById('s-online').textContent = Object.keys(val).length;
  });

  // all players (for rendering others' positions)
  onValue(ref(db, 'players'), snap => {
    const val = snap.val() || {};
    otherPlayers = {};
    for (const [k, v] of Object.entries(val)) {
      if (k !== me.name) otherPlayers[k] = v;
    }
  });

  // owned creatures across all players (for rendering, filter mine)
  onValue(ref(db, 'creatures'), snap => {
    const val = snap.val() || {};
    ownedCreatures = {};
    for (const [k, v] of Object.entries(val)) {
      if (v.owner === me.name) ownedCreatures[k] = { ...v, id: k };
    }
    renderCreaturesTab();
  });

  // buildings
  onValue(ref(db, 'buildings'), snap => {
    buildings = snap.val() || {};
    renderBuildingsTab();
  });

  // depleted resources (respawn timers)
  onValue(ref(db, 'depleted'), snap => {
    depletedResources = snap.val() || {};
  });
}

// ============================================================
// RENDERING
// ============================================================
function fitCanvas() {
  const wrap = document.getElementById('world-wrap');
  const w = wrap.clientWidth;
  const h = wrap.clientHeight;
  canvas.width = w;
  canvas.height = h;
  // Dynamic tile size: aim for ~VIEW_TILES across, min 16px
  const size = Math.max(18, Math.min(40, Math.floor(Math.min(w, h) / VIEW_TILES)));
  tilePx = size;
}

window.addEventListener('resize', () => { if (me) fitCanvas(); });

function render() {
  if (!world || !me) return;
  const w = canvas.width, h = canvas.height;
  const cols = Math.ceil(w / tilePx) + 1;
  const rows = Math.ceil(h / tilePx) + 1;
  const originX = me.x - Math.floor(cols / 2);
  const originY = me.y - Math.floor(rows / 2);

  ctx.fillStyle = '#0a0e0c';
  ctx.fillRect(0, 0, w, h);

  ctx.font = `${tilePx * 0.7}px 'JetBrains Mono', monospace`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';

  // draw terrain
  for (let ry = 0; ry < rows; ry++) {
    for (let rx = 0; rx < cols; rx++) {
      const wx = originX + rx;
      const wy = originY + ry;
      const px = rx * tilePx;
      const py = ry * tilePx;
      if (wx < 0 || wy < 0 || wx >= WORLD_SIZE || wy >= WORLD_SIZE) {
        ctx.fillStyle = '#000';
        ctx.fillRect(px, py, tilePx, tilePx);
        continue;
      }
      const tile = world[wy][wx];
      const biome = BIOMES[tile.biome];
      // Checkerboard shading for depth
      const shade = ((wx + wy) % 2 === 0) ? biome.color : biome.colorLite;
      ctx.fillStyle = shade;
      ctx.fillRect(px, py, tilePx, tilePx);

      // terrain glyph (subtle)
      ctx.fillStyle = 'rgba(200,180,140,0.15)';
      ctx.fillText(biome.glyph, px + tilePx/2, py + tilePx/2);

      // resource (not depleted)
      const depKey = `${wx}_${wy}`;
      const isDepleted = depletedResources[depKey] && depletedResources[depKey] > Date.now();
      if (tile.resource && !isDepleted) {
        ctx.fillStyle = '#fff';
        ctx.fillText(RESOURCES[tile.resource].glyph, px + tilePx/2, py + tilePx/2);
      }
    }
  }

  // draw buildings
  for (const [id, b] of Object.entries(buildings)) {
    if (b.x < originX || b.x >= originX + cols || b.y < originY || b.y >= originY + rows) continue;
    const px = (b.x - originX) * tilePx;
    const py = (b.y - originY) * tilePx;
    ctx.fillStyle = 'rgba(255,179,71,0.15)';
    ctx.fillRect(px, py, tilePx, tilePx);
    ctx.fillText(BUILDINGS[b.type].icon, px + tilePx/2, py + tilePx/2);
    // health bar for low-hp buildings
    if (b.hp < BUILDINGS[b.type].hp) {
      const pct = b.hp / BUILDINGS[b.type].hp;
      ctx.fillStyle = '#000';
      ctx.fillRect(px + 2, py + tilePx - 5, tilePx - 4, 3);
      ctx.fillStyle = pct > 0.5 ? '#7cbd56' : pct > 0.25 ? '#ffb347' : '#d35454';
      ctx.fillRect(px + 2, py + tilePx - 5, (tilePx - 4) * pct, 3);
    }
  }

  // draw wild creatures
  for (const c of wildCreatures) {
    if (c.x < originX || c.x >= originX + cols || c.y < originY || c.y >= originY + rows) continue;
    const px = (c.x - originX) * tilePx;
    const py = (c.y - originY) * tilePx;
    ctx.fillText(SPECIES[c.species].glyph, px + tilePx/2, py + tilePx/2);
  }

  // draw other players
  for (const [name, p] of Object.entries(otherPlayers)) {
    if (p.x < originX || p.x >= originX + cols || p.y < originY || p.y >= originY + rows) continue;
    const px = (p.x - originX) * tilePx;
    const py = (p.y - originY) * tilePx;
    ctx.fillStyle = 'rgba(106,176,196,0.25)';
    ctx.fillRect(px, py, tilePx, tilePx);
    ctx.fillStyle = '#6ab0c4';
    ctx.font = `${tilePx * 0.7}px 'JetBrains Mono', monospace`;
    ctx.fillText('🧍', px + tilePx/2, py + tilePx/2);
    // name tag
    ctx.font = `bold 10px 'JetBrains Mono', monospace`;
    ctx.fillStyle = '#6ab0c4';
    ctx.fillText(name, px + tilePx/2, py - 2);
    ctx.font = `${tilePx * 0.7}px 'JetBrains Mono', monospace`;
  }

  // draw me (centered)
  const meX = (me.x - originX) * tilePx;
  const meY = (me.y - originY) * tilePx;
  ctx.fillStyle = 'rgba(255,179,71,0.25)';
  ctx.fillRect(meX, meY, tilePx, tilePx);
  ctx.strokeStyle = '#ffb347';
  ctx.lineWidth = 2;
  ctx.strokeRect(meX + 1, meY + 1, tilePx - 2, tilePx - 2);
  ctx.fillStyle = '#fff';
  ctx.fillText('🧍', meX + tilePx/2, meY + tilePx/2);

  // place-building overlay
  if (placingBuilding) {
    ctx.strokeStyle = 'rgba(124,189,86,0.6)';
    ctx.lineWidth = 1;
    ctx.setLineDash([4, 4]);
    const adjTiles = [[me.x, me.y-1],[me.x, me.y+1],[me.x-1, me.y],[me.x+1, me.y]];
    for (const [ax, ay] of adjTiles) {
      if (ax < originX || ax >= originX + cols || ay < originY || ay >= originY + rows) continue;
      const ok = canPlaceHere(ax, ay);
      ctx.strokeStyle = ok ? 'rgba(124,189,86,0.7)' : 'rgba(211,84,84,0.7)';
      ctx.strokeRect((ax - originX) * tilePx + 2, (ay - originY) * tilePx + 2, tilePx - 4, tilePx - 4);
    }
    ctx.setLineDash([]);
  }

  renderMinimap();
  updateHud();
}

function renderMinimap() {
  const size = miniCanvas.width;
  const scale = size / WORLD_SIZE;
  for (let y = 0; y < WORLD_SIZE; y++) {
    for (let x = 0; x < WORLD_SIZE; x++) {
      miniCtx.fillStyle = BIOMES[world[y][x].biome].color;
      miniCtx.fillRect(x * scale, y * scale, scale + 1, scale + 1);
    }
  }
  // other players
  for (const p of Object.values(otherPlayers)) {
    miniCtx.fillStyle = '#6ab0c4';
    miniCtx.fillRect(p.x * scale - 1, p.y * scale - 1, 3, 3);
  }
  // buildings
  for (const b of Object.values(buildings)) {
    miniCtx.fillStyle = b.owner === me.name ? '#ffb347' : '#d35454';
    miniCtx.fillRect(b.x * scale, b.y * scale, 2, 2);
  }
  // me
  miniCtx.fillStyle = '#ffb347';
  miniCtx.fillRect(me.x * scale - 2, me.y * scale - 2, 5, 5);
  // viewport box
  miniCtx.strokeStyle = 'rgba(255,179,71,0.6)';
  miniCtx.lineWidth = 1;
  const viewW = Math.min(WORLD_SIZE, Math.ceil(canvas.width / tilePx)) * scale;
  const viewH = Math.min(WORLD_SIZE, Math.ceil(canvas.height / tilePx)) * scale;
  miniCtx.strokeRect(me.x * scale - viewW/2, me.y * scale - viewH/2, viewW, viewH);
}

function updateHud() {
  const biome = world[me.y][me.x].biome;
  document.getElementById('hud-hp').textContent = `${me.hp}/${me.maxHp}`;
  document.getElementById('hud-gold').textContent = me.gold;
  document.getElementById('hud-pos').textContent = `${me.x},${me.y}`;
  document.getElementById('hud-biome').textContent = BIOMES[biome].name;
  // stats tab mirrors
  document.getElementById('s-hp').textContent = `${me.hp}/${me.maxHp}`;
  document.getElementById('s-lvl').textContent = me.lvl;
  document.getElementById('s-xp').textContent = `${me.xp}/${me.lvl * 100}`;
  document.getElementById('s-gold').textContent = me.gold;
  document.getElementById('s-pos').textContent = `${me.x},${me.y}`;
  document.getElementById('s-biome').textContent = BIOMES[biome].name;
}

// ============================================================
// INPUT
// ============================================================
document.addEventListener('keydown', e => {
  if (document.activeElement?.tagName === 'INPUT') return;
  keys[e.key.toLowerCase()] = true;
  if (e.key === ' ') { e.preventDefault(); interactAtPlayer(); }
  if (e.key === 'Tab') { e.preventDefault(); cycleTab(); }
});
document.addEventListener('keyup', e => { keys[e.key.toLowerCase()] = false; });

// dpad
document.querySelectorAll('.dpad-btn[data-dir]').forEach(btn => {
  const dir = btn.dataset.dir;
  const handler = (e) => {
    e.preventDefault();
    if (dir === 'up') tryMove(0, -1);
    else if (dir === 'down') tryMove(0, 1);
    else if (dir === 'left') tryMove(-1, 0);
    else if (dir === 'right') tryMove(1, 0);
    else if (dir === 'act') interactAtPlayer();
  };
  btn.addEventListener('touchstart', handler, { passive: false });
  btn.addEventListener('click', handler);
});

// canvas click to interact
canvas.addEventListener('click', e => {
  const rect = canvas.getBoundingClientRect();
  const cx = e.clientX - rect.left;
  const cy = e.clientY - rect.top;
  const cols = Math.ceil(canvas.width / tilePx) + 1;
  const rows = Math.ceil(canvas.height / tilePx) + 1;
  const originX = me.x - Math.floor(cols / 2);
  const originY = me.y - Math.floor(rows / 2);
  const tx = Math.floor(cx / tilePx) + originX;
  const ty = Math.floor(cy / tilePx) + originY;

  if (placingBuilding) {
    tryPlaceBuilding(tx, ty);
    return;
  }

  // only interact if adjacent or on player tile
  const dist = Math.max(Math.abs(tx - me.x), Math.abs(ty - me.y));
  if (dist > 1) {
    log(`too far — move closer`, 'info');
    return;
  }
  interactAt(tx, ty);
});

function interactAtPlayer() {
  interactAt(me.x, me.y);
  // also check all 4 adj
  const adj = [[me.x, me.y-1],[me.x, me.y+1],[me.x-1, me.y],[me.x+1, me.y]];
  for (const [x, y] of adj) {
    // prefer creatures
    const c = wildCreatures.find(c => c.x === x && c.y === y);
    if (c) { initiateCombat(c); return; }
  }
}

function interactAt(x, y) {
  if (x < 0 || y < 0 || x >= WORLD_SIZE || y >= WORLD_SIZE) return;
  // creature?
  const c = wildCreatures.find(c => c.x === x && c.y === y);
  if (c) { initiateCombat(c); return; }
  // building of mine?
  const bEntry = Object.entries(buildings).find(([id, b]) => b.x === x && b.y === y);
  if (bEntry) { openBuilding(bEntry[0], bEntry[1]); return; }
  // resource?
  const tile = world[y][x];
  const depKey = `${x}_${y}`;
  if (tile.resource && !(depletedResources[depKey] && depletedResources[depKey] > Date.now())) {
    gatherResource(x, y, tile.resource);
    return;
  }
  log(`nothing here.`, 'info');
}

// ============================================================
// MOVEMENT
// ============================================================
function tryMove(dx, dy) {
  const now = performance.now();
  if (now - lastMoveTime < MOVE_COOLDOWN) return;
  lastMoveTime = now;
  const nx = me.x + dx, ny = me.y + dy;
  if (nx < 0 || ny < 0 || nx >= WORLD_SIZE || ny >= WORLD_SIZE) return;
  const tile = world[ny][nx];
  if (!BIOMES[tile.biome].walkable) { log(`can't walk on ${BIOMES[tile.biome].name}`, 'info'); return; }
  // blocked by non-walkable buildings
  const blocking = Object.values(buildings).find(b => b.x === nx && b.y === ny && !BUILDINGS[b.type].walkable);
  if (blocking) { log(`blocked by ${BUILDINGS[blocking.type].name}`, 'info'); return; }
  me.x = nx; me.y = ny;
  update(ref(db, `players/${me.name}`), { x: nx, y: ny });
}

// ============================================================
// RESOURCE GATHERING
// ============================================================
async function gatherResource(x, y, resKey) {
  const res = RESOURCES[resKey];
  // tool bonus
  const hasMatchingTool = Object.keys(me.tools || {}).some(t => ITEMS[t]?.bonus === res.drops);
  const amt = res.amount + (hasMatchingTool ? 1 : 0);
  me.inv[res.drops] = (me.inv[res.drops] || 0) + amt;
  log(`+${amt} ${ITEMS[res.drops].name}`, 'good');
  // deplete
  const depKey = `${x}_${y}`;
  await update(ref(db, `depleted`), { [depKey]: Date.now() + RESPAWN_MS });
  await update(ref(db, `players/${me.name}`), { inv: me.inv });
  renderInvTab();
}

// ============================================================
// COMBAT
// ============================================================
function initiateCombat(wildCreature) {
  const sp = SPECIES[wildCreature.species];
  const lvl = wildCreature.lvl;
  const enemy = {
    species: wildCreature.species,
    lvl,
    hp: Math.floor(sp.base.hp * (1 + lvl * 0.15)),
    maxHp: Math.floor(sp.base.hp * (1 + lvl * 0.15)),
    atk: Math.floor(sp.base.atk * (1 + lvl * 0.12)),
    def: Math.floor(sp.base.def * (1 + lvl * 0.10)),
    spd: sp.base.spd,
  };
  combatState = { enemy, wildId: wildCreature.id, wild: wildCreature, log: [] };
  openCombatModal();
}

function playerStats() {
  let atk = 8 + me.lvl * 2;
  let def = 4 + me.lvl;
  if (me.tools?.stone_sword) atk += 10;
  if (me.tools?.leather_armor) def += 8;
  return { atk, def, spd: 20 };
}

function openCombatModal() {
  const { enemy, log: cLog } = combatState;
  const sp = SPECIES[enemy.species];
  const ps = playerStats();
  const body = `
    <div class="combat-arena">
      <div class="combat-side">
        <div class="combat-sprite">🧍</div>
        <div class="combat-name">${me.name}</div>
        <div class="combat-lvl">LV ${me.lvl}</div>
        <div class="combat-hp-label">HP</div>
        <div class="bar"><div class="bar-fill hp" style="transform:scaleX(${me.hp/me.maxHp})"></div></div>
        <div style="font-size:10px;color:var(--text-dim)">
          ATK ${ps.atk} · DEF ${ps.def} · SPD ${ps.spd}
        </div>
      </div>
      <div class="combat-vs">VS</div>
      <div class="combat-side">
        <div class="combat-sprite">${sp.glyph}</div>
        <div class="combat-name">Wild ${sp.name}</div>
        <div class="combat-lvl">LV ${enemy.lvl}</div>
        <div class="combat-hp-label">HP</div>
        <div class="bar"><div class="bar-fill hp" style="transform:scaleX(${enemy.hp/enemy.maxHp})"></div></div>
        <div style="font-size:10px;color:var(--text-dim)">
          ATK ${enemy.atk} · DEF ${enemy.def} · SPD ${enemy.spd}
        </div>
      </div>
    </div>
    <div id="combat-log">${cLog.map(l => `<div>${l}</div>`).join('')}</div>
    <div class="combat-actions">
      <button class="btn primary" onclick="window.__combatAction('attack')">⚔ Attack</button>
      <button class="btn" onclick="window.__combatAction('tame')" ${me.tools?.tame_net ? '' : 'disabled'}>🕸 Tame Net${me.tools?.tame_net ? ' ('+me.tools.tame_net+')' : ''}</button>
      <button class="btn" onclick="window.__combatAction('item')" disabled>🧪 Item</button>
      <button class="btn danger" onclick="window.__combatAction('flee')">🏃 Flee</button>
    </div>
  `;
  openModal(`Wild ${sp.name} · LV ${enemy.lvl}`, body, []);
}

window.__combatAction = (action) => {
  const { enemy } = combatState;
  const ps = playerStats();
  const sp = SPECIES[enemy.species];

  if (action === 'flee') {
    if (Math.random() < 0.7 || ps.spd >= enemy.spd) {
      combatState.log.push(`<span class="log-info">You fled.</span>`);
      log(`fled from wild ${sp.name}`, 'info');
      closeModal();
      combatState = null;
    } else {
      combatState.log.push(`<span class="log-bad">Couldn't escape!</span>`);
      enemyTurn();
    }
    return;
  }

  if (action === 'attack') {
    // player goes first if spd >= enemy spd
    if (ps.spd >= enemy.spd) {
      playerHit();
      if (enemy.hp > 0) enemyTurn();
    } else {
      enemyTurn();
      if (me.hp > 0) playerHit();
    }
    postCombatCheck();
    return;
  }

  if (action === 'tame') {
    if (!me.tools?.tame_net || me.tools.tame_net <= 0) return;
    me.tools.tame_net--;
    if (me.tools.tame_net <= 0) delete me.tools.tame_net;
    // catch rate: based on enemy hp %, lower = easier
    const hpFrac = enemy.hp / enemy.maxHp;
    const catchRate = Math.max(0.08, 0.9 - hpFrac * 0.7);
    const ownedCount = Object.keys(ownedCreatures).length;
    if (ownedCount >= MAX_CREATURES_OWNED) {
      combatState.log.push(`<span class="log-bad">Creature slots full!</span>`);
      openCombatModal();
      return;
    }
    if (Math.random() < catchRate) {
      // Caught — persist to DB with rolled IVs
      const cid = push(child(ref(db), 'creatures')).key;
      const ivs = {
        hp: Math.floor(Math.random() * 32),
        atk: Math.floor(Math.random() * 32),
        def: Math.floor(Math.random() * 32),
        spd: Math.floor(Math.random() * 32),
      };
      const critter = {
        species: enemy.species,
        owner: me.name,
        lvl: enemy.lvl,
        xp: 0,
        hp: enemy.maxHp,
        maxHp: enemy.maxHp,
        ivs,
        traits: [],
        caughtAt: Date.now(),
      };
      set(ref(db, `creatures/${cid}`), critter);
      combatState.log.push(`<span class="log-good">✓ Caught ${sp.name}!</span>`);
      log(`tamed wild ${sp.name} LV ${enemy.lvl}`, 'good');
      update(ref(db, `players/${me.name}`), { tools: me.tools });
      // remove wild creature from this session (will respawn next time bucket)
      wildCreatures = wildCreatures.filter(c => c.id !== combatState.wildId);
      closeModal();
      combatState = null;
      return;
    } else {
      combatState.log.push(`<span class="log-bad">${sp.name} broke free!</span>`);
      update(ref(db, `players/${me.name}`), { tools: me.tools });
      enemyTurn();
      postCombatCheck();
      return;
    }
  }
};

function playerHit() {
  const ps = playerStats();
  const base = Math.max(1, ps.atk - combatState.enemy.def / 2);
  const dmg = Math.floor(base * (0.85 + Math.random() * 0.3));
  combatState.enemy.hp = Math.max(0, combatState.enemy.hp - dmg);
  combatState.log.push(`<span class="log-good">You hit for ${dmg}</span>`);
}

function enemyTurn() {
  const ps = playerStats();
  const base = Math.max(1, combatState.enemy.atk - ps.def / 2);
  const dmg = Math.floor(base * (0.85 + Math.random() * 0.3));
  me.hp = Math.max(0, me.hp - dmg);
  combatState.log.push(`<span class="log-bad">${SPECIES[combatState.enemy.species].name} hit you for ${dmg}</span>`);
  update(ref(db, `players/${me.name}`), { hp: me.hp });
}

function postCombatCheck() {
  if (combatState.enemy.hp <= 0) {
    const goldDrop = 5 + combatState.enemy.lvl * 3;
    const xpGain = 20 + combatState.enemy.lvl * 10;
    me.gold += goldDrop;
    me.xp += xpGain;
    // level up?
    while (me.xp >= me.lvl * 100) {
      me.xp -= me.lvl * 100;
      me.lvl++;
      me.maxHp += 10;
      me.hp = me.maxHp;
      log(`LEVEL UP — now level ${me.lvl}`, 'system');
    }
    log(`defeated ${SPECIES[combatState.enemy.species].name} · +${goldDrop}g +${xpGain}xp`, 'good');
    update(ref(db, `players/${me.name}`), { gold: me.gold, xp: me.xp, lvl: me.lvl, maxHp: me.maxHp, hp: me.hp });
    wildCreatures = wildCreatures.filter(c => c.id !== combatState.wildId);
    closeModal();
    combatState = null;
    return;
  }
  if (me.hp <= 0) {
    log(`you died — respawning`, 'bad');
    me.hp = Math.floor(me.maxHp * 0.5);
    me.x = 25; me.y = 25;
    // drop inventory (per spec)
    me.inv = {};
    update(ref(db, `players/${me.name}`), { hp: me.hp, x: me.x, y: me.y, inv: me.inv });
    closeModal();
    combatState = null;
    renderInvTab();
    return;
  }
  openCombatModal();
}

// ============================================================
// CRAFTING
// ============================================================
function renderCraftTab() {
  const el = document.getElementById('recipes');
  el.innerHTML = '';
  for (const r of RECIPES) {
    const out = ITEMS[r.out];
    const costParts = Object.entries(r.req).map(([k, v]) => {
      const have = me.inv[k] || 0;
      const cls = have >= v ? 'have' : 'need';
      return `<span class="${cls}">${v} ${ITEMS[k].name}</span>`;
    }).join(' · ');
    const canCraft = Object.entries(r.req).every(([k, v]) => (me.inv[k] || 0) >= v);
    const div = document.createElement('div');
    div.className = 'recipe' + (canCraft ? '' : ' disabled');
    div.innerHTML = `
      <div class="head">
        <span><span class="icon">${out.icon}</span> ${out.name} ×${r.qty}</span>
        <span style="color:${canCraft ? 'var(--green)' : 'var(--red)'}">${canCraft ? '✓' : '✕'}</span>
      </div>
      <div class="cost">${costParts}</div>
    `;
    if (canCraft) div.addEventListener('click', () => craft(r));
    el.appendChild(div);
  }
}

function craft(recipe) {
  // deduct
  for (const [k, v] of Object.entries(recipe.req)) {
    me.inv[k] -= v;
    if (me.inv[k] <= 0) delete me.inv[k];
  }
  // add output
  const out = ITEMS[recipe.out];
  if (out.consumable || !out.tool) {
    me.tools[recipe.out] = (me.tools[recipe.out] || 0) + recipe.qty;
  } else {
    me.tools[recipe.out] = 1; // unique tool
  }
  log(`crafted ${out.name} ×${recipe.qty}`, 'good');
  update(ref(db, `players/${me.name}`), { inv: me.inv, tools: me.tools });
  renderCraftTab();
  renderInvTab();
}

// ============================================================
// BUILDING
// ============================================================
function renderBuildTab() {
  const el = document.getElementById('buildings');
  el.innerHTML = '';
  for (const [key, b] of Object.entries(BUILDINGS)) {
    const costParts = Object.entries(b.req).map(([k, v]) => {
      const have = me.inv[k] || 0;
      const cls = have >= v ? 'have' : 'need';
      return `<span class="${cls}">${v} ${ITEMS[k].name}</span>`;
    }).join(' · ');
    const canBuild = Object.entries(b.req).every(([k, v]) => (me.inv[k] || 0) >= v);
    const div = document.createElement('div');
    div.className = 'build-opt' + (canBuild ? '' : ' disabled');
    div.innerHTML = `
      <div class="head"><span><span class="icon">${b.icon}</span> ${b.name}</span><span style="font-size:10px;color:var(--text-dim)">HP ${b.hp}</span></div>
      <div class="cost">${costParts}</div>
    `;
    if (canBuild) div.addEventListener('click', () => startPlacing(key));
    el.appendChild(div);
  }
  // my bases
  const mine = Object.entries(buildings).filter(([, b]) => b.owner === me.name);
  const basesEl = document.getElementById('my-bases');
  if (mine.length === 0) {
    basesEl.innerHTML = '<div style="color:var(--text-faded);font-style:italic">no structures yet</div>';
  } else {
    basesEl.innerHTML = mine.map(([id, b]) =>
      `<div style="padding:4px 0;border-bottom:1px solid var(--border)">${BUILDINGS[b.type].icon} ${BUILDINGS[b.type].name} @ ${b.x},${b.y} · ${b.hp}/${BUILDINGS[b.type].hp} HP</div>`
    ).join('');
  }
}

function startPlacing(type) {
  placingBuilding = type;
  log(`click adjacent tile to place ${BUILDINGS[type].name} · esc to cancel`, 'system');
}

function canPlaceHere(x, y) {
  if (x < 0 || y < 0 || x >= WORLD_SIZE || y >= WORLD_SIZE) return false;
  const dx = Math.abs(x - me.x), dy = Math.abs(y - me.y);
  if (dx + dy !== 1) return false;
  const tile = world[y][x];
  if (!BIOMES[tile.biome].walkable) return false;
  if (tile.biome === 'water') return false;
  if (Object.values(buildings).some(b => b.x === x && b.y === y)) return false;
  return true;
}

async function tryPlaceBuilding(x, y) {
  if (!placingBuilding) return;
  if (!canPlaceHere(x, y)) { log(`can't place there`, 'bad'); return; }
  const b = BUILDINGS[placingBuilding];
  for (const [k, v] of Object.entries(b.req)) {
    me.inv[k] -= v;
    if (me.inv[k] <= 0) delete me.inv[k];
  }
  const id = push(child(ref(db), 'buildings')).key;
  await set(ref(db, `buildings/${id}`), {
    type: placingBuilding, x, y, owner: me.name, hp: b.hp, built: Date.now()
  });
  await update(ref(db, `players/${me.name}`), { inv: me.inv });
  log(`built ${b.name} @ ${x},${y}`, 'good');
  placingBuilding = null;
  renderBuildTab();
  renderInvTab();
}

document.addEventListener('keydown', e => {
  if (e.key === 'Escape' && placingBuilding) {
    placingBuilding = null;
    log(`canceled building`, 'info');
  }
});

// ============================================================
// BUILDING INTERACTION
// ============================================================
function openBuilding(id, b) {
  if (b.type === 'storage' && b.owner === me.name) {
    openStorage(id, b);
  } else if (b.type === 'bench' && b.owner === me.name) {
    switchTab('craft');
    log(`using stone workbench`, 'info');
  } else if (b.owner !== me.name) {
    confirmAttackBuilding(id, b);
  } else {
    log(`${BUILDINGS[b.type].name}`, 'info');
  }
}

function openStorage(id, b) {
  const stored = b.contents || {};
  const allItems = { ...me.inv, ...me.tools };
  const body = `
    <div class="section-title">Inventory → Storage</div>
    <div class="inv-grid" id="inv-side"></div>
    <div class="section-title" style="margin-top:12px">Storage</div>
    <div class="inv-grid" id="stor-side"></div>
  `;
  openModal('Storage Box', body, [{ label: 'Close', action: closeModal }]);
  const invSide = document.getElementById('inv-side');
  const storSide = document.getElementById('stor-side');
  const renderSlots = () => {
    invSide.innerHTML = '';
    storSide.innerHTML = '';
    const myAll = { ...me.inv };
    for (const [k, v] of Object.entries(myAll)) {
      const s = document.createElement('div');
      s.className = 'inv-slot';
      s.innerHTML = `<span class="count">${v}</span><div class="icon">${ITEMS[k].icon}</div><div class="name">${ITEMS[k].name}</div>`;
      s.addEventListener('click', async () => {
        me.inv[k]--;
        if (me.inv[k] <= 0) delete me.inv[k];
        const nc = { ...(b.contents || {}) };
        nc[k] = (nc[k] || 0) + 1;
        b.contents = nc;
        await update(ref(db, `buildings/${id}`), { contents: nc });
        await update(ref(db, `players/${me.name}`), { inv: me.inv });
        renderSlots();
        renderInvTab();
      });
      invSide.appendChild(s);
    }
    for (const [k, v] of Object.entries(b.contents || {})) {
      const s = document.createElement('div');
      s.className = 'inv-slot';
      s.innerHTML = `<span class="count">${v}</span><div class="icon">${ITEMS[k].icon}</div><div class="name">${ITEMS[k].name}</div>`;
      s.addEventListener('click', async () => {
        const nc = { ...(b.contents || {}) };
        nc[k]--;
        if (nc[k] <= 0) delete nc[k];
        b.contents = nc;
        me.inv[k] = (me.inv[k] || 0) + 1;
        await update(ref(db, `buildings/${id}`), { contents: nc });
        await update(ref(db, `players/${me.name}`), { inv: me.inv });
        renderSlots();
        renderInvTab();
      });
      storSide.appendChild(s);
    }
    if (!Object.keys(me.inv).length) invSide.innerHTML = '<div class="empty-state">inventory empty</div>';
    if (!Object.keys(b.contents || {}).length) storSide.innerHTML = '<div class="empty-state">storage empty</div>';
  };
  renderSlots();
}

function confirmAttackBuilding(id, b) {
  const body = `
    <div style="padding:10px 0">This is <b style="color:var(--red)">${b.owner}</b>'s ${BUILDINGS[b.type].name}.</div>
    <div style="color:var(--text-dim);font-size:11px">Attack to damage it. Destroy to loot contents if any.</div>
    <div style="margin-top:12px">HP: <b style="color:${b.hp < BUILDINGS[b.type].hp/2 ? 'var(--red)' : 'var(--amber)'}">${b.hp}/${BUILDINGS[b.type].hp}</b></div>
  `;
  openModal('⚔ Enemy Structure', body, [
    { label: 'Attack (-10 HP)', action: () => attackBuilding(id, b), danger: true },
    { label: 'Leave', action: closeModal },
  ]);
}

async function attackBuilding(id, b) {
  const dmg = 10 + (me.tools?.stone_sword ? 8 : 0);
  const newHp = b.hp - dmg;
  if (newHp <= 0) {
    // destroyed — loot contents
    const loot = b.contents || {};
    for (const [k, v] of Object.entries(loot)) {
      me.inv[k] = (me.inv[k] || 0) + v;
    }
    await update(ref(db, `players/${me.name}`), { inv: me.inv });
    await remove(ref(db, `buildings/${id}`));
    log(`destroyed ${b.owner}'s ${BUILDINGS[b.type].name} · looted ${Object.keys(loot).length} items`, 'good');
    renderInvTab();
    closeModal();
  } else {
    await update(ref(db, `buildings/${id}`), { hp: newHp });
    log(`hit ${b.owner}'s ${BUILDINGS[b.type].name} for ${dmg}`, 'info');
    b.hp = newHp;
    confirmAttackBuilding(id, b);
  }
}

// ============================================================
// INVENTORY RENDER
// ============================================================
function renderInvTab() {
  const resEl = document.getElementById('inv-resources');
  const toolEl = document.getElementById('inv-tools');
  const resKeys = ['wood','stone','copper','iron','food'];
  const toolKeys = Object.keys(ITEMS).filter(k => ITEMS[k].tool);
  const fillGrid = (el, keys, source) => {
    el.innerHTML = '';
    for (const k of keys) {
      const v = source[k] || 0;
      const slot = document.createElement('div');
      slot.className = 'inv-slot' + (v === 0 ? ' empty' : '');
      slot.innerHTML = `<span class="count">${v}</span><div class="icon">${ITEMS[k].icon}</div><div class="name">${ITEMS[k].name}</div>`;
      el.appendChild(slot);
    }
  };
  fillGrid(resEl, resKeys, me.inv || {});
  fillGrid(toolEl, toolKeys, me.tools || {});
}

// ============================================================
// CREATURES TAB
// ============================================================
function renderCreaturesTab() {
  const el = document.getElementById('crit-list');
  const list = Object.values(ownedCreatures);
  document.getElementById('crit-count').textContent = list.length;
  if (list.length === 0) {
    el.innerHTML = '<div class="empty-state">no creatures tamed yet<br>craft a Tame Net and find a wild one</div>';
    return;
  }
  el.innerHTML = '';
  for (const c of list) {
    const sp = SPECIES[c.species];
    const card = document.createElement('div');
    card.className = 'creature-card';
    const totalIVs = Object.values(c.ivs || {}).reduce((a,b)=>a+b,0);
    card.innerHTML = `
      <div class="sprite">${sp.glyph}</div>
      <div class="info">
        <div class="row-1"><span class="species">${sp.name}</span><span class="lvl">LV ${c.lvl}</span></div>
        <div class="stats-mini">HP ${c.hp}/${c.maxHp} · IVs ${totalIVs}/124</div>
      </div>
    `;
    card.addEventListener('click', () => openCreatureDetail(c));
    el.appendChild(card);
  }
}

function openCreatureDetail(c) {
  const sp = SPECIES[c.species];
  const statAt = (base, iv) => Math.floor((base + iv) * (1 + c.lvl * 0.1));
  const ivColor = iv => iv === 31 ? 'perfect' : '';
  const body = `
    <div style="display:grid;grid-template-columns:60px 1fr;gap:12px;align-items:center;padding:10px 0 14px">
      <div style="font-size:48px;text-align:center">${sp.glyph}</div>
      <div>
        <div style="font-size:16px;font-weight:700;color:var(--text)">${sp.name}</div>
        <div style="font-size:11px;color:var(--text-dim)">Level ${c.lvl} · ${c.xp || 0}/${c.lvl * 80} XP</div>
      </div>
    </div>
    <div class="section-title">Stats (base + IV × level)</div>
    <div class="stat-grid">
      <span class="k">HP</span><span class="v">${statAt(sp.base.hp, c.ivs.hp)}</span>
      <span class="k">ATK</span><span class="v">${statAt(sp.base.atk, c.ivs.atk)}</span>
      <span class="k">DEF</span><span class="v">${statAt(sp.base.def, c.ivs.def)}</span>
      <span class="k">SPD</span><span class="v">${statAt(sp.base.spd, c.ivs.spd)}</span>
    </div>
    <div class="section-title" style="margin-top:12px">IVs (0-31, inheritable)</div>
    <div class="iv-grid">
      <span class="k">HP IV</span><span class="v ${ivColor(c.ivs.hp)}">${c.ivs.hp}/31</span>
      <span class="k">ATK IV</span><span class="v ${ivColor(c.ivs.atk)}">${c.ivs.atk}/31</span>
      <span class="k">DEF IV</span><span class="v ${ivColor(c.ivs.def)}">${c.ivs.def}/31</span>
      <span class="k">SPD IV</span><span class="v ${ivColor(c.ivs.spd)}">${c.ivs.spd}/31</span>
    </div>
  `;
  openModal(`${sp.name} LV ${c.lvl}`, body, [
    { label: 'Release', action: () => releaseCreature(c), danger: true },
    { label: 'Close', action: closeModal },
  ]);
}

async function releaseCreature(c) {
  await remove(ref(db, `creatures/${c.id}`));
  log(`released ${SPECIES[c.species].name}`, 'info');
  closeModal();
}

// ============================================================
// TABS
// ============================================================
document.querySelectorAll('.tab').forEach(t => {
  t.addEventListener('click', () => switchTab(t.dataset.tab));
});

function switchTab(name) {
  currentTab = name;
  document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.tab === name));
  document.querySelectorAll('.tab-content').forEach(c => c.style.display = 'none');
  document.getElementById(`tab-${name}`).style.display = 'block';
  if (name === 'inv') renderInvTab();
  if (name === 'crit') renderCreaturesTab();
  if (name === 'craft') renderCraftTab();
  if (name === 'build') renderBuildTab();
}

function cycleTab() {
  const order = ['stats','inv','crit','craft','build'];
  const i = order.indexOf(currentTab);
  switchTab(order[(i + 1) % order.length]);
}

// ============================================================
// MODAL
// ============================================================
function openModal(title, bodyHTML, btns = []) {
  document.getElementById('modal-title').textContent = title;
  document.getElementById('modal-body').innerHTML = bodyHTML;
  const btnsEl = document.getElementById('modal-btns');
  btnsEl.innerHTML = '';
  for (const b of btns) {
    const btn = document.createElement('button');
    btn.className = 'btn' + (b.primary ? ' primary' : '') + (b.danger ? ' danger' : '');
    btn.textContent = b.label;
    btn.addEventListener('click', b.action);
    btnsEl.appendChild(btn);
  }
  document.getElementById('modal-bg').classList.add('open');
}

function closeModal() {
  document.getElementById('modal-bg').classList.remove('open');
  document.getElementById('modal-body').innerHTML = '';
}

document.getElementById('modal-close').addEventListener('click', () => {
  if (combatState) return; // can't close mid-combat; must flee
  closeModal();
});

// ============================================================
// GAME LOOP
// ============================================================
let lastWildUpdate = 0;
function startGameLoop() {
  function loop(ts) {
    // continuous movement from held keys
    if (!combatState && !placingBuilding) {
      if (keys['w'] || keys['arrowup']) tryMove(0, -1);
      else if (keys['s'] || keys['arrowdown']) tryMove(0, 1);
      else if (keys['a'] || keys['arrowleft']) tryMove(-1, 0);
      else if (keys['d'] || keys['arrowright']) tryMove(1, 0);
    }

    // wild creatures: regenerate list each 4s bucket (they "wander")
    const bucket = Math.floor(Date.now() / CREATURE_MOVE_MS);
    if (bucket !== lastWildUpdate) {
      lastWildUpdate = bucket;
      wildCreatures = getWildCreatures(worldSeed, bucket);
    }

    render();
    requestAnimationFrame(loop);
  }
  requestAnimationFrame(loop);
  renderInvTab();
}

// Keep session alive heartbeat (Firebase ondisconnect handles drops)
setInterval(() => {
  if (me) {
    update(ref(db, `online/${me.name}`), { at: serverTimestamp() });
  }
}, 30_000);

</script>
