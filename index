<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="mobile-web-app-capable" content="yes">
<title>FERAL // Survival</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=VT323&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0f0d;
    --bg-panel: #141a18;
    --bg-inset: #0e1412;
    --border: #2d3a35;
    --border-bright: #4a5e55;
    --text: #d4c5a0;
    --text-dim: #8a9b8e;
    --text-faded: #566561;
    --amber: #ffb347;
    --amber-dim: #b87a28;
    --green: #7cbd56;
    --green-dim: #4d7a33;
    --red: #d35454;
    --red-dim: #8a2828;
    --blue: #6ab0c4;
    --purple: #a87ec8;
    --tile: 22px;
    --mono: 'JetBrains Mono', ui-monospace, monospace;
    --display: 'VT323', 'JetBrains Mono', monospace;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    height: 100%;
    overflow: hidden;
    background: var(--bg);
    color: var(--text);
    font-family: var(--mono);
    font-size: 13px;
    -webkit-tap-highlight-color: transparent;
    user-select: none;
    -webkit-user-select: none;
  }

  body {
    background:
      radial-gradient(ellipse at 20% 10%, rgba(255,179,71,0.04), transparent 50%),
      radial-gradient(ellipse at 80% 90%, rgba(124,189,86,0.03), transparent 50%),
      var(--bg);
  }

  /* subtle CRT scanlines */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    background: repeating-linear-gradient(
      0deg,
      rgba(0,0,0,0.08) 0px,
      rgba(0,0,0,0.08) 1px,
      transparent 1px,
      transparent 3px
    );
    z-index: 9999;
    opacity: 0.4;
  }

  /* ================ LOADING / LOGIN ================ */
  #login {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    z-index: 100;
    padding: 20px;
  }

  #login h1 {
    font-family: var(--display);
    font-size: 72px;
    letter-spacing: 8px;
    color: var(--amber);
    text-shadow: 0 0 20px rgba(255,179,71,0.5), 0 0 40px rgba(255,179,71,0.2);
    margin-bottom: 8px;
  }

  #login .subtitle {
    font-size: 11px;
    letter-spacing: 4px;
    color: var(--text-dim);
    margin-bottom: 40px;
    text-transform: uppercase;
  }

  #login .box {
    background: var(--bg-panel);
    border: 1px solid var(--border);
    padding: 24px;
    max-width: 380px;
    width: 100%;
  }

  #login label {
    display: block;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  #login input {
    width: 100%;
    background: var(--bg-inset);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: var(--mono);
    font-size: 14px;
    padding: 10px 12px;
    margin-bottom: 16px;
    outline: none;
  }

  #login input:focus {
    border-color: var(--amber);
  }

  #login button {
    width: 100%;
    background: var(--amber);
    color: var(--bg);
    border: none;
    font-family: var(--mono);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 2px;
    padding: 12px;
    cursor: pointer;
    text-transform: uppercase;
  }

  #login button:hover { background: #ffc96b; }
  #login button:disabled { opacity: 0.5; cursor: not-allowed; }

  #login .status {
    margin-top: 16px;
    font-size: 11px;
    color: var(--text-dim);
    text-align: center;
    min-height: 14px;
  }
  #login .err { color: var(--red); }

  #login .footer {
    margin-top: 30px;
    font-size: 10px;
    color: var(--text-faded);
    text-align: center;
    letter-spacing: 1px;
  }

  /* ================ GAME LAYOUT ================ */
  #game { display: none; height: 100vh; width: 100vw; }
  #game.active { display: grid; grid-template-columns: 1fr 320px; }

  @media (max-width: 860px) {
    #game.active { grid-template-columns: 1fr; grid-template-rows: 1fr auto; }
  }

  /* ================ WORLD VIEW ================ */
  #world-wrap {
    position: relative;
    overflow: hidden;
    background: var(--bg-inset);
    border-right: 1px solid var(--border);
  }

  @media (max-width: 860px) {
    #world-wrap { border-right: none; border-bottom: 1px solid var(--border); }
  }

  #world {
    display: block;
    background: #0d110f;
    image-rendering: pixelated;
  }

  /* HUD overlays */
  .hud {
    position: absolute;
    background: rgba(10, 15, 13, 0.88);
    border: 1px solid var(--border);
    padding: 8px 12px;
    backdrop-filter: blur(4px);
    font-size: 11px;
    pointer-events: none;
  }

  #hud-top-left { top: 10px; left: 10px; min-width: 170px; }
  #hud-top-right { top: 10px; right: 10px; }
  #hud-bottom-left { bottom: 10px; left: 10px; }

  .hud-row {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    line-height: 1.6;
  }

  .hud-label { color: var(--text-dim); letter-spacing: 1px; }
  .hud-val { color: var(--amber); font-weight: 700; }
  .hud-val.green { color: var(--green); }
  .hud-val.red { color: var(--red); }

  /* Minimap */
  #minimap {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 150px;
    height: 150px;
    background: rgba(10, 15, 13, 0.88);
    border: 1px solid var(--border);
    backdrop-filter: blur(4px);
  }
  @media (max-width: 860px) { #minimap { width: 100px; height: 100px; } }

  /* Log */
  #log {
    position: absolute;
    bottom: 10px;
    left: 10px;
    width: 380px;
    max-width: calc(100% - 20px);
    max-height: 140px;
    background: rgba(10, 15, 13, 0.88);
    border: 1px solid var(--border);
    backdrop-filter: blur(4px);
    overflow-y: auto;
    font-size: 11px;
    line-height: 1.6;
    padding: 8px 12px;
  }
  @media (max-width: 860px) { #log { max-height: 80px; width: 240px; } }

  #log::-webkit-scrollbar { width: 4px; }
  #log::-webkit-scrollbar-track { background: transparent; }
  #log::-webkit-scrollbar-thumb { background: var(--border); }

  .log-entry { margin-bottom: 2px; }
  .log-time { color: var(--text-faded); margin-right: 8px; }
  .log-info { color: var(--text); }
  .log-good { color: var(--green); }
  .log-bad { color: var(--red); }
  .log-system { color: var(--amber); }

  /* Virtual dpad (mobile) */
  #dpad {
    position: absolute;
    bottom: 20px;
    right: 20px;
    display: none;
    grid-template-columns: repeat(3, 52px);
    grid-template-rows: repeat(3, 52px);
    gap: 2px;
    z-index: 5;
  }
  @media (hover: none) and (pointer: coarse) { #dpad { display: grid; } }

  .dpad-btn {
    background: rgba(20, 26, 24, 0.85);
    border: 1px solid var(--border-bright);
    color: var(--amber);
    font-family: var(--mono);
    font-size: 18px;
    font-weight: 700;
    user-select: none;
    -webkit-user-select: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .dpad-btn:active { background: rgba(255,179,71,0.2); }
  .dpad-btn.empty { visibility: hidden; }

  /* ================ SIDE PANEL ================ */
  #panel {
    background: var(--bg-panel);
    border-left: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  @media (max-width: 860px) {
    #panel { border-left: none; max-height: 40vh; }
  }

  .brand {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .brand .logo {
    font-family: var(--display);
    font-size: 24px;
    letter-spacing: 4px;
    color: var(--amber);
    text-shadow: 0 0 10px rgba(255,179,71,0.3);
  }
  .brand .nickname {
    font-size: 11px;
    color: var(--text-dim);
  }
  .brand .nickname .name { color: var(--green); font-weight: 700; }

  .tabs {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    border-bottom: 1px solid var(--border);
    background: var(--bg-inset);
  }
  .tab {
    padding: 10px 4px;
    text-align: center;
    font-size: 10px;
    letter-spacing: 1.5px;
    color: var(--text-dim);
    cursor: pointer;
    border-right: 1px solid var(--border);
    text-transform: uppercase;
    font-weight: 500;
  }
  .tab:last-child { border-right: none; }
  .tab.active {
    color: var(--amber);
    background: var(--bg-panel);
    box-shadow: inset 0 2px 0 var(--amber);
  }
  .tab:hover:not(.active) { color: var(--text); }

  .tab-content {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
  }
  .tab-content::-webkit-scrollbar { width: 6px; }
  .tab-content::-webkit-scrollbar-track { background: var(--bg-inset); }
  .tab-content::-webkit-scrollbar-thumb { background: var(--border-bright); }

  .section-title {
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 10px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--border);
  }

  .stat-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px 12px;
    font-size: 11px;
    margin-bottom: 16px;
  }
  .stat-grid .k { color: var(--text-dim); }
  .stat-grid .v { color: var(--amber); text-align: right; font-weight: 700; }
  .stat-grid .v.green { color: var(--green); }

  .bar {
    height: 6px;
    background: var(--bg-inset);
    border: 1px solid var(--border);
    position: relative;
    margin-bottom: 10px;
  }
  .bar-fill { position: absolute; inset: 0; transform-origin: left; }
  .bar-fill.hp { background: var(--red); }
  .bar-fill.xp { background: var(--amber); }

  .inv-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
    margin-bottom: 16px;
  }
  .inv-slot {
    background: var(--bg-inset);
    border: 1px solid var(--border);
    padding: 8px 6px;
    text-align: center;
    font-size: 10px;
    position: relative;
    min-height: 56px;
  }
  .inv-slot .icon { font-size: 20px; line-height: 1; }
  .inv-slot .name { color: var(--text-dim); margin-top: 4px; font-size: 9px; letter-spacing: 0.5px; }
  .inv-slot .count {
    position: absolute;
    top: 4px;
    right: 6px;
    font-weight: 700;
    color: var(--amber);
    font-size: 11px;
  }
  .inv-slot.empty { opacity: 0.3; }

  .creature-card {
    background: var(--bg-inset);
    border: 1px solid var(--border);
    padding: 10px;
    margin-bottom: 8px;
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: 10px;
    align-items: center;
    cursor: pointer;
  }
  .creature-card:hover { border-color: var(--border-bright); }
  .creature-card .sprite {
    font-size: 28px;
    text-align: center;
    line-height: 1;
  }
  .creature-card .info { min-width: 0; }
  .creature-card .row-1 {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    margin-bottom: 4px;
  }
  .creature-card .species { color: var(--text); font-weight: 700; }
  .creature-card .lvl { color: var(--amber); }
  .creature-card .stats-mini {
    font-size: 9px;
    color: var(--text-dim);
    letter-spacing: 1px;
  }

  .recipe, .build-opt {
    background: var(--bg-inset);
    border: 1px solid var(--border);
    padding: 10px;
    margin-bottom: 8px;
    cursor: pointer;
  }
  .recipe:hover, .build-opt:hover { border-color: var(--amber); }
  .recipe.disabled, .build-opt.disabled { opacity: 0.4; cursor: not-allowed; }
  .recipe:hover.disabled, .build-opt:hover.disabled { border-color: var(--border); }
  .recipe .head, .build-opt .head {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 4px;
  }
  .recipe .icon, .build-opt .icon { font-size: 16px; }
  .recipe .cost, .build-opt .cost {
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 0.5px;
  }
  .recipe .cost .have { color: var(--green); }
  .recipe .cost .need { color: var(--red); }

  .empty-state {
    text-align: center;
    color: var(--text-faded);
    padding: 30px 10px;
    font-size: 11px;
    font-style: italic;
  }

  /* ================ MODAL ================ */
  #modal-bg {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 50;
    backdrop-filter: blur(2px);
    padding: 20px;
  }
  #modal-bg.open { display: flex; }
  .modal {
    background: var(--bg-panel);
    border: 1px solid var(--border-bright);
    max-width: 440px;
    width: 100%;
    box-shadow: 0 10px 40px rgba(0,0,0,0.6);
  }
  .modal-head {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .modal-title {
    font-family: var(--display);
    font-size: 22px;
    letter-spacing: 3px;
    color: var(--amber);
  }
  .modal-close {
    background: none;
    border: none;
    color: var(--text-dim);
    cursor: pointer;
    font-family: var(--mono);
    font-size: 18px;
  }
  .modal-body { padding: 16px; }
  .modal-btns {
    padding: 12px 16px;
    border-top: 1px solid var(--border);
    display: flex;
    gap: 8px;
    justify-content: flex-end;
  }

  .btn {
    background: var(--bg-inset);
    border: 1px solid var(--border-bright);
    color: var(--text);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 1px;
    padding: 8px 14px;
    cursor: pointer;
    text-transform: uppercase;
  }
  .btn:hover { border-color: var(--amber); color: var(--amber); }
  .btn.primary { background: var(--amber); color: var(--bg); border-color: var(--amber); font-weight: 700; }
  .btn.primary:hover { background: #ffc96b; color: var(--bg); }
  .btn.danger { background: var(--red-dim); color: var(--text); border-color: var(--red); }
  .btn.danger:hover { background: var(--red); }
  .btn:disabled { opacity: 0.4; cursor: not-allowed; }

  /* Combat modal specifics */
  .combat-arena {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 16px;
    align-items: center;
    padding: 16px;
    background: var(--bg-inset);
    border: 1px solid var(--border);
    margin-bottom: 12px;
  }
  .combat-side { text-align: center; }
  .combat-sprite { font-size: 48px; line-height: 1; margin-bottom: 8px; }
  .combat-name { font-weight: 700; color: var(--text); margin-bottom: 2px; }
  .combat-lvl { font-size: 10px; color: var(--text-dim); letter-spacing: 1px; margin-bottom: 8px; }
  .combat-hp-label { font-size: 9px; color: var(--text-dim); letter-spacing: 1px; margin-bottom: 2px; }
  .combat-vs {
    font-family: var(--display);
    font-size: 32px;
    color: var(--amber);
    letter-spacing: 2px;
  }
  .combat-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
  }
  #combat-log {
    max-height: 100px;
    overflow-y: auto;
    font-size: 11px;
    line-height: 1.6;
    padding: 8px;
    background: var(--bg-inset);
    border: 1px solid var(--border);
    margin-bottom: 12px;
  }

  /* place building modal shows options */
  .place-hint {
    font-size: 11px;
    color: var(--amber);
    text-align: center;
    padding: 8px;
    background: rgba(255,179,71,0.1);
    border: 1px dashed var(--amber);
    margin-bottom: 12px;
  }

  /* creature detail */
  .iv-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 4px 16px;
    font-size: 10px;
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px solid var(--border);
  }
  .iv-grid .k { color: var(--text-dim); }
  .iv-grid .v { color: var(--amber); text-align: right; }
  .iv-grid .v.perfect { color: var(--green); }

  /* config warning */
  #config-warn {
    position: fixed;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--red-dim);
    color: var(--text);
    border: 1px solid var(--red);
    padding: 8px 16px;
    font-size: 11px;
    letter-spacing: 1px;
    z-index: 200;
    display: none;
  }
</style>
</head>
<body>

<!-- ============== CONFIG WARNING ============== -->
<div id="config-warn">⚠ FIREBASE CONFIG NOT SET — see README.md</div>

<!-- ============== LOGIN ============== -->
<div id="login">
  <h1>FERAL</h1>
  <div class="subtitle">survival · taming · ruin</div>
  <div class="box">
    <label for="nick-input">enter nickname</label>
    <input id="nick-input" type="text" maxlength="16" placeholder="raider42" autocomplete="off">
    <button id="enter-btn">enter world</button>
    <div class="status" id="login-status"></div>
  </div>
  <div class="footer">5 player max · data persists · share the link</div>
</div>

<!-- ============== GAME ============== -->
<div id="game">
  <div id="world-wrap">
    <canvas id="world"></canvas>

    <div id="hud-top-left" class="hud">
      <div class="hud-row"><span class="hud-label">HP</span><span class="hud-val red" id="hud-hp">100/100</span></div>
      <div class="hud-row"><span class="hud-label">GOLD</span><span class="hud-val" id="hud-gold">0</span></div>
      <div class="hud-row"><span class="hud-label">POS</span><span class="hud-val green" id="hud-pos">0,0</span></div>
      <div class="hud-row"><span class="hud-label">BIOME</span><span class="hud-val" id="hud-biome">—</span></div>
    </div>

    <canvas id="minimap" width="150" height="150"></canvas>

    <div id="log"></div>

    <div id="dpad">
      <div class="dpad-btn empty"></div>
      <div class="dpad-btn" data-dir="up">▲</div>
      <div class="dpad-btn empty"></div>
      <div class="dpad-btn" data-dir="left">◀</div>
      <div class="dpad-btn" data-dir="act">•</div>
      <div class="dpad-btn" data-dir="right">▶</div>
      <div class="dpad-btn empty"></div>
      <div class="dpad-btn" data-dir="down">▼</div>
      <div class="dpad-btn empty"></div>
    </div>
  </div>

  <aside id="panel">
    <div class="brand">
      <div class="logo">FERAL</div>
      <div class="nickname">playing as <span class="name" id="brand-name">—</span></div>
    </div>

    <div class="tabs">
      <div class="tab active" data-tab="stats">Stats</div>
      <div class="tab" data-tab="inv">Inv</div>
      <div class="tab" data-tab="crit">Tame</div>
      <div class="tab" data-tab="craft">Craft</div>
      <div class="tab" data-tab="build">Build</div>
    </div>

    <div class="tab-content" id="tab-stats">
      <div class="section-title">Status</div>
      <div class="stat-grid">
        <span class="k">Health</span><span class="v red" id="s-hp">100/100</span>
        <span class="k">Level</span><span class="v" id="s-lvl">1</span>
        <span class="k">XP</span><span class="v" id="s-xp">0/100</span>
        <span class="k">Gold</span><span class="v" id="s-gold">0</span>
        <span class="k">Position</span><span class="v green" id="s-pos">0,0</span>
        <span class="k">Biome</span><span class="v" id="s-biome">—</span>
      </div>
      <div class="section-title">Controls</div>
      <div style="font-size:11px;line-height:1.8;color:var(--text-dim)">
        <div><span style="color:var(--amber)">WASD</span> / <span style="color:var(--amber)">arrows</span> — move</div>
        <div><span style="color:var(--amber)">Click</span> tile — interact</div>
        <div><span style="color:var(--amber)">Space</span> — gather/attack on tile</div>
        <div><span style="color:var(--amber)">Tab</span> — cycle panels</div>
      </div>
      <div class="section-title" style="margin-top:16px">Session</div>
      <div style="font-size:11px;color:var(--text-dim);line-height:1.8">
        <div>Online: <span id="s-online" style="color:var(--green)">0</span> / 5</div>
        <div>World seed: <span id="s-seed" style="color:var(--amber)">—</span></div>
      </div>
    </div>

    <div class="tab-content" id="tab-inv" style="display:none">
      <div class="section-title">Resources</div>
      <div class="inv-grid" id="inv-resources"></div>
      <div class="section-title">Tools &amp; Gear</div>
      <div class="inv-grid" id="inv-tools"></div>
    </div>

