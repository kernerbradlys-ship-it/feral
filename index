// ============================================================
// PRNG + world gen (deterministic from seed)
// ============================================================
function mulberry32(seed) {
  return function() {
    let t = seed += 0x6D2B79F5;
    t = Math.imul(t ^ t >>> 15, t | 1);
    t ^= t + Math.imul(t ^ t >>> 7, t | 61);
    return ((t ^ t >>> 14) >>> 0) / 4294967296;
  };
}

// Simple value-noise-ish lookup for biome assignment
function noise2(seed, x, y) {
  const h = (x * 374761393 + y * 668265263 + seed * 2246822519) | 0;
  const n = (h ^ (h >>> 13)) * 1274126177;
  return ((n ^ (n >>> 16)) >>> 0) / 4294967296;
}

function smoothNoise(seed, x, y, scale) {
  const xs = x / scale, ys = y / scale;
  const xi = Math.floor(xs), yi = Math.floor(ys);
  const xf = xs - xi, yf = ys - yi;
  const n00 = noise2(seed, xi, yi);
  const n10 = noise2(seed, xi + 1, yi);
  const n01 = noise2(seed, xi, yi + 1);
  const n11 = noise2(seed, xi + 1, yi + 1);
  const u = xf * xf * (3 - 2 * xf);
  const v = yf * yf * (3 - 2 * yf);
  return (n00 * (1 - u) + n10 * u) * (1 - v) + (n01 * (1 - u) + n11 * u) * v;
}

function generateWorld(seed) {
  const map = [];
  for (let y = 0; y < WORLD_SIZE; y++) {
    map[y] = [];
    for (let x = 0; x < WORLD_SIZE; x++) {
      const elev = smoothNoise(seed, x, y, 8) * 0.6 + smoothNoise(seed + 1, x, y, 3) * 0.4;
      const moist = smoothNoise(seed + 91, x, y, 10);
      const caveNoise = smoothNoise(seed + 173, x, y, 4);

      let biome;
      if (elev < 0.30) biome = 'water';
      else if (elev < 0.36) biome = 'sand';
      else if (elev > 0.78) biome = 'mountain';
      else if (caveNoise > 0.82 && elev > 0.5) biome = 'cave';
      else if (moist > 0.6) biome = 'forest';
      else biome = 'grass';

      map[y][x] = { biome, resource: null };

      // Resource seeding based on biome (deterministic)
      const r = noise2(seed + 777, x, y);
      if (biome === 'forest' && r < 0.25) map[y][x].resource = 'tree';
      else if (biome === 'forest' && r < 0.28) map[y][x].resource = 'berry';
      else if (biome === 'grass' && r < 0.08) map[y][x].resource = 'tree';
      else if (biome === 'grass' && r < 0.12) map[y][x].resource = 'rock';
      else if (biome === 'grass' && r < 0.15) map[y][x].resource = 'berry';
      else if (biome === 'mountain' && r < 0.20) map[y][x].resource = 'rock';
      else if (biome === 'mountain' && r < 0.24) map[y][x].resource = 'copper';
      else if (biome === 'cave' && r < 0.20) map[y][x].resource = 'iron';
      else if (biome === 'cave' && r < 0.30) map[y][x].resource = 'copper';
      else if (biome === 'cave' && r < 0.38) map[y][x].resource = 'rock';
    }
  }
  return map;
}

// Deterministic wild creature placement based on seed + time bucket
// (they "wander" as the bucket rolls over; no server state needed)
function getWildCreatures(seed, timeBucket) {
  const creatures = [];
  const rng = mulberry32(seed ^ (timeBucket * 31337));
  const target = 40; // wild creature count on map
  let placed = 0, tries = 0;
  while (placed < target && tries < 600) {
    tries++;
    const x = Math.floor(rng() * WORLD_SIZE);
    const y = Math.floor(rng() * WORLD_SIZE);
    const tile = world[y]?.[x];
    if (!tile) continue;
    // find a species that spawns here
    const candidates = Object.keys(SPECIES).filter(k => SPECIES[k].biomes.includes(tile.biome));
    if (!candidates.length) continue;
    const species = candidates[Math.floor(rng() * candidates.length)];
    const lvl = 1 + Math.floor(rng() * 8);
    creatures.push({ id: `w_${timeBucket}_${x}_${y}`, wild: true, species, x, y, lvl });
    placed++;
  }
  return creatures;
}

